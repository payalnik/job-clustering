# Copy to `.env` and fill in real values.
# Loaded by `jobproc.config` (reads os.environ first, then this file).

# --- PostgreSQL ---
# Any Postgres 16+ instance with the pgvector extension installed.
JOBPROC_DB_HOST=localhost
JOBPROC_DB_PORT=5432
JOBPROC_DB_NAME=jobproc
JOBPROC_DB_USER=jobproc
JOBPROC_DB_PASSWORD=changeme

# --- Gemini ---
# Get a key from https://aistudio.google.com/apikey
# The embedding pipeline uses `gemini-embedding-2-preview` (768-dim).
GEMINI_API_KEY=

# --- Ingestion tuning (optional) ---
# How many ATS endpoints to hit in parallel. Keep <=15 to avoid rate limits.
JOBPROC_PARALLEL=10
# Cap per Gemini embedding batch. 100 is the API's documented max.
JOBPROC_EMBED_BATCH=100
# Sleep between batches (seconds) — leaves headroom for concurrent work.
JOBPROC_EMBED_SLEEP=3
